{
  "compilerOptions": {
    "rootDir": ".",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {}
  },
  "include": [
    "src/**/*",
    "test/unit/**/*",
    "test/integration/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}

{
  "compilerOptions": {
    "rootDir": ".",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "paths": {}
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "playground/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}

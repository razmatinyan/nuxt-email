# Copy to playground/.env and fill in the providers you want to test.
# Without any changes, the playground defaults to `console` (logs emails to terminal).

# Default provider used when no provider is chosen in the UI: console | resend | sendgrid | postmark | smtp
NUXT_EMAIL_PROVIDER=console

# Default sender address (e.g. "My App <noreply@example.com>")
NUXT_EMAIL_FROM=

# Per-provider API keys. Fill the ones you want to test and switch between them in the UI.
NUXT_EMAIL_RESEND_API_KEY=
NUXT_EMAIL_SENDGRID_API_KEY=
NUXT_EMAIL_POSTMARK_API_KEY=

# SMTP settings (used when the smtp provider is selected)
NUXT_EMAIL_SMTP_HOST=
NUXT_EMAIL_SMTP_PORT=587
NUXT_EMAIL_SMTP_USER=
NUXT_EMAIL_SMTP_PASS=
NUXT_EMAIL_SMTP_SECURE=false

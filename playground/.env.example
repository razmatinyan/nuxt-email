# Copy to playground/.env and fill in values for the provider you want to test.
# Without any changes, the playground defaults to `console` (logs emails to terminal).

# Which provider to use: console | resend | sendgrid | postmark | smtp
NUXT_EMAIL_PROVIDER=console

# API key for Resend, SendGrid, or Postmark
NUXT_EMAIL_API_KEY=

# Default sender address (e.g. "My App <noreply@example.com>")
NUXT_EMAIL_FROM=

# SMTP settings (only needed when NUXT_EMAIL_PROVIDER=smtp)
NUXT_EMAIL_SMTP_HOST=
NUXT_EMAIL_SMTP_PORT=587
NUXT_EMAIL_SMTP_USER=
NUXT_EMAIL_SMTP_PASS=
NUXT_EMAIL_SMTP_SECURE=false
